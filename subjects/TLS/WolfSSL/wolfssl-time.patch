+++ b/wolfcrypt/src/asn.c
@@ -36,6 +36,9 @@
  */
 
 #include <wolfssl/wolfcrypt/libwolfssl_sources.h>
+#include <stdlib.h>
+#include <stdio.h>
+#include <time.h>
 
 /*
 ASN Options:
@@ -17073,10 +17076,60 @@ int wc_SetTimeCb(wc_time_cb f)
 
 time_t wc_Time(time_t* t)
 {
+    time_t now;
+    time_t out;
+    struct tm tm_val;
+    int year, mon, mday, hour, min, sec;
+    char* fake_time;
+    static int fake_time_initialized = 0;
+    static int fake_time_enabled = 0;
+    static time_t fake_base_time = 0;
+    static time_t real_base_time = 0;
+
     if (timeFunc != NULL) {
         return timeFunc(t);
     }
-    return XTIME(t);
+
+    now = XTIME(NULL);
+
+    if (!fake_time_initialized) {
+        fake_time_initialized = 1;
+        real_base_time = now;
+
+        fake_time = getenv("FAKE_TIME");
+        if (fake_time != NULL && fake_time[0] != '\0') {
+            XMEMSET(&tm_val, 0, sizeof(tm_val));
+            if (sscanf(fake_time, "%d-%d-%d %d:%d:%d",
+                       &year, &mon, &mday, &hour, &min, &sec) == 6) {
+                tm_val.tm_year = year - 1900;
+                tm_val.tm_mon = mon - 1;
+                tm_val.tm_mday = mday;
+                tm_val.tm_hour = hour;
+                tm_val.tm_min = min;
+                tm_val.tm_sec = sec;
+                {
+                    time_t parsed = mktime(&tm_val);
+                    if (parsed != (time_t)-1) {
+                        fake_time_enabled = 1;
+                        fake_base_time = parsed;
+                    }
+                }
+            }
+        }
+    }
+
+    if (fake_time_enabled) {
+        out = fake_base_time + (now - real_base_time);
+    }
+    else {
+        out = now;
+    }
+
+    if (t != NULL) {
+        *t = out;
+    }
+
+    return out;
 }
 
 #endif /* !NO_ASN_TIME */

