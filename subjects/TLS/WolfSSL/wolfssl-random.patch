diff --git a/wolfcrypt/src/random.c b/wolfcrypt/src/random.c
index 6886a5869..cab4091ee 100644
--- a/wolfcrypt/src/random.c
+++ b/wolfcrypt/src/random.c
@@ -72,6 +72,7 @@ This library contains implementation for the random number generator.
     #include <wolfssl/wolfcrypt/rng_bank.h>
 #endif
 #include <wolfssl/wolfcrypt/cpuid.h>
+#include <stdlib.h>
 
 #ifndef WC_NO_RNG /* if not FIPS and RNG is disabled then do not compile */
 
@@ -1351,6 +1352,22 @@ int wc_RNG_GenerateBlock(WC_RNG* rng, byte* output, word32 sz)
     if (sz == 0)
         return 0;
 
+    if (getenv("FAKE_RANDOM") != NULL) {
+        static int fake_seed_initialized = 0;
+        static unsigned int fake_seed = 0;
+
+        if (!fake_seed_initialized) {
+            char* seed_str = getenv("FAKERANDOM_SEED");
+            fake_seed = (seed_str != NULL) ? (unsigned int)atoi(seed_str) : 0;
+            fake_seed_initialized = 1;
+        }
+
+        for (word32 i = 0; i < sz; ++i) {
+            output[i] = (byte)(rand_r(&fake_seed) % 256);
+        }
+        return 0;
+    }
+
 #ifdef WOLF_CRYPTO_CB
     #ifndef WOLF_CRYPTO_CB_FIND
     if (rng->devId != INVALID_DEVID)
