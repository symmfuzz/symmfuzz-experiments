 # include "internal/e_os.h"
 # include "internal/property.h"
 
+static int pfb_fake_random_enabled = -1;
+static unsigned int pfb_fake_random_seed = 1;
+
+static int pfb_is_fake_random_enabled(void)
+{
+    const char *env = NULL;
+    char *endptr = NULL;
+    unsigned long seed = 0;
+
+    if (pfb_fake_random_enabled != -1)
+        return pfb_fake_random_enabled;
+
+    env = getenv("FAKE_RANDOM");
+    if (env == NULL || env[0] == '\0' || strcmp(env, "0") == 0) {
+        pfb_fake_random_enabled = 0;
+        return 0;
+    }
+    pfb_fake_random_enabled = 1;
+
+    env = getenv("FAKE_RANDOM_SEED");
+    if (env != NULL && env[0] != '\0') {
+        seed = strtoul(env, &endptr, 10);
+        if (endptr != env)
+            pfb_fake_random_seed = (unsigned int)seed;
+    }
+
+    return 1;
+}
+
+static void pfb_fill_fake_random(unsigned char *buf, size_t num)
+{
+    size_t i;
+    for (i = 0; i < num; ++i)
+        buf[i] = (unsigned char)(rand_r(&pfb_fake_random_seed) & 0xFF);
+}
