-    CXPLAT_DBG_ASSERT(ErrorCode == 0);
-    UNREFERENCED_PARAMETER(ErrorCode);
+    NowUs = CxPlatTimeUs64();
+    Time->tv_sec = (time_t)(NowUs / CXPLAT_MICROSEC_PER_SEC);
+    Time->tv_nsec = (long)((NowUs % CXPLAT_MICROSEC_PER_SEC) * CXPLAT_NANOSEC_PER_MICROSEC);
 
     Time->tv_sec += (DeltaMs / CXPLAT_MS_PER_SECOND);
     Time->tv_nsec += ((DeltaMs % CXPLAT_MS_PER_SECOND) * CXPLAT_NANOSEC_PER_MS);
@@ -540,6 +663,17 @@ CxPlatRandom(
