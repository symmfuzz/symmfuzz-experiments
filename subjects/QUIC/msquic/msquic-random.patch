+static bool CxPlatFakeTimeInitialized = false;
+static bool CxPlatFakeTimeEnabled = false;
+static uint64_t CxPlatFakeTimeBaseUs = 0;
+static uint64_t CxPlatRealTimeBaseUs = 0;
+
+static bool CxPlatFakeRandomInitialized = false;
+static bool CxPlatFakeRandomEnabled = false;
+static unsigned int CxPlatFakeRandomSeed = 1;
+
+static
+bool
+CxPlatEnvEnabled(
+    _In_z_ const char* Name
+    )
+{
+    const char* Value = getenv(Name);
+    if (Value == NULL || Value[0] == '\0' || strcmp(Value, "0") == 0) {
+        return false;
+    }
+    return true;
+}
+
+static
+bool
+CxPlatTryParseFakeTimeUs(
+    _In_z_ const char* Value,
+    _Out_ uint64_t* FakeTimeUs
+    )
+{
+    int Year = 0, Month = 0, Day = 0, Hour = 0, Minute = 0, Second = 0;
+    struct tm Tm = {0};
+    time_t Epoch = 0;
+
+    if (Value == NULL || FakeTimeUs == NULL) {
+        return false;
+    }
+
+    if (sscanf(Value, "%d-%d-%d %d:%d:%d",
+               &Year, &Month, &Day, &Hour, &Minute, &Second) == 6) {
+        Tm.tm_year = Year - 1900;
+        Tm.tm_mon = Month - 1;
+        Tm.tm_mday = Day;
+        Tm.tm_hour = Hour;
+        Tm.tm_min = Minute;
+        Tm.tm_sec = Second;
+        Tm.tm_isdst = -1;
+        Epoch = mktime(&Tm);
+        if (Epoch == (time_t)-1) {
+            return false;
+        }
+        *FakeTimeUs = (uint64_t)Epoch * CXPLAT_MICROSEC_PER_SEC;
+        return true;
+    }
+
+    return false;
+}
+
+static
+uint64_t
+CxPlatGetRealMonotonicUs(
+    void
+    )
+{
+    struct timespec CurrTime = {0};
+    int ErrorCode = clock_gettime(CLOCK_MONOTONIC, &CurrTime);
+    CXPLAT_DBG_ASSERT(ErrorCode == 0);
+    UNREFERENCED_PARAMETER(ErrorCode);
+    return ((uint64_t)CurrTime.tv_sec * CXPLAT_MICROSEC_PER_SEC) +
+           ((uint64_t)CurrTime.tv_nsec / CXPLAT_NANOSEC_PER_MICROSEC);
+}
+
+static
+void
+CxPlatInitFakeTimeState(
+    void
+    )
+{
+    const char* FakeTimeEnv = NULL;
+    uint64_t ParsedFakeTimeUs = 0;
+
+    if (CxPlatFakeTimeInitialized) {
+        return;
+    }
+    CxPlatFakeTimeInitialized = true;
+
+    FakeTimeEnv = getenv("FAKE_TIME");
+    if (CxPlatTryParseFakeTimeUs(FakeTimeEnv, &ParsedFakeTimeUs)) {
+        CxPlatFakeTimeEnabled = true;
+        CxPlatFakeTimeBaseUs = ParsedFakeTimeUs;
+        CxPlatRealTimeBaseUs = CxPlatGetRealMonotonicUs();
+    }
+}
+
+static
+void
+CxPlatInitFakeRandomState(
+    void
+    )
+{
+    const char* SeedEnv = NULL;
+    char* EndPtr = NULL;
+    unsigned long SeedValue = 0;
+
+    if (CxPlatFakeRandomInitialized) {
+        return;
+    }
+    CxPlatFakeRandomInitialized = true;
+    CxPlatFakeRandomEnabled = CxPlatEnvEnabled("FAKE_RANDOM");
+    if (!CxPlatFakeRandomEnabled) {
+        return;
+    }
+
+    SeedEnv = getenv("FAKE_RANDOM_SEED");
+    if (SeedEnv == NULL || SeedEnv[0] == '\0') {
+        CxPlatFakeRandomSeed = 1;
+        return;
+    }
+
+    SeedValue = strtoul(SeedEnv, &EndPtr, 10);
+    if (EndPtr == SeedEnv) {
+        CxPlatFakeRandomSeed = 1;
+    } else {
+        CxPlatFakeRandomSeed = (unsigned int)SeedValue;
+    }
+}
+
