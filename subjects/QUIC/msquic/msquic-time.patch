+static int pfb_parse_fake_time(time_t *out)
+{
+    const char *env = getenv("FAKE_TIME");
+    struct tm tmv;
+    int year = 0, mon = 0, mday = 0, hour = 0, min = 0, sec = 0;
+    char *endptr = NULL;
+    long long epoch = 0;
+
+    if (env == NULL || env[0] == '\0')
+        return 0;
+
+    if (sscanf(env, "%d-%d-%d %d:%d:%d",
+               &year, &mon, &mday, &hour, &min, &sec) == 6) {
+        memset(&tmv, 0, sizeof(tmv));
+        tmv.tm_year = year - 1900;
+        tmv.tm_mon = mon - 1;
+        tmv.tm_mday = mday;
+        tmv.tm_hour = hour;
+        tmv.tm_min = min;
+        tmv.tm_sec = sec;
+        tmv.tm_isdst = -1;
+        *out = mktime(&tmv);
+        return *out != (time_t)-1;
+    }
+
+    epoch = strtoll(env, &endptr, 10);
+    if (endptr != env) {
+        *out = (time_t)epoch;
+        return 1;
+    }
+
+    return 0;
+}
