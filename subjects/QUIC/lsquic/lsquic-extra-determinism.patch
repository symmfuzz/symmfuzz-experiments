diff --git a/src/liblsquic/lsquic_util.c b/src/liblsquic/lsquic_util.c
index 2f24130..5659ea8 100644
--- a/src/liblsquic/lsquic_util.c
+++ b/src/liblsquic/lsquic_util.c
@@ -145,6 +145,49 @@ lsquic_time_now (void)
 }
 
 
+time_t
+lsquic_time_now_sec (void)
+{
+    return (time_t) (lsquic_time_now() / 1000000);
+}
+
+
+uint32_t
+lsquic_rand_u32 (void)
+{
+    static int initialized;
+    static uint32_t state;
+    const char *fake_env;
+    const char *seed_env;
+    char *endptr;
+
+    if (!initialized)
+    {
+        initialized = 1;
+        fake_env = getenv("FAKE_RANDOM");
+        seed_env = getenv("FAKERANDOM_SEED");
+        if (fake_env && fake_env[0] && strcmp(fake_env, "0") != 0)
+        {
+            if (seed_env && seed_env[0])
+            {
+                unsigned long parsed = strtoul(seed_env, &endptr, 10);
+                if (endptr != seed_env)
+                    state = (uint32_t) parsed;
+            }
+            if (state == 0)
+                state = 1u;
+        }
+        else
+            state = (uint32_t) lsquic_time_now() ^ (uint32_t) (uintptr_t) &state;
+    }
+
+    state = state * 1664525u + 1013904223u;
+    if (state == 0)
+        state = 1u;
+    return state;
+}
+
