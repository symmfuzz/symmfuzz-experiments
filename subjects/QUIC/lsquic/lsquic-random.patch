diff --git a/crypto/rand/rand.cc b/crypto/rand/rand.cc
index 2aa30270a..424a63c06 100644
--- a/crypto/rand/rand.cc
+++ b/crypto/rand/rand.cc
@@ -13,6 +13,8 @@
 // limitations under the License.
 
 #include <limits.h>
+#include <cstdlib>
+#include <cstring>
 
 #include <openssl/rand.h>
 
@@ -22,7 +24,40 @@
 
 using namespace bssl;
 
+namespace {
+
+bool fake_random_enabled() {
+  const char *env = getenv("FAKE_RANDOM");
+  return env != nullptr && env[0] != '\0' && strcmp(env, "0") != 0;
+}
+
+uint32_t &fake_random_seed() {
+  static uint32_t seed = 1;
+  static bool initialized = false;
+  if (!initialized) {
+    const char *seed_env = getenv("FAKERANDOM_SEED");
+    if (seed_env != nullptr && seed_env[0] != '\0') {
+      unsigned long parsed = strtoul(seed_env, nullptr, 10);
+      if (parsed != 0) {
+        seed = static_cast<uint32_t>(parsed);
+      }
+    }
+    initialized = true;
+  }
+  return seed;
+}
+
+}  // namespace
+
 int RAND_bytes(uint8_t *buf, size_t len) {
+  if (fake_random_enabled()) {
+    uint32_t &seed = fake_random_seed();
+    for (size_t i = 0; i < len; ++i) {
+      buf[i] = static_cast<uint8_t>(rand_r(&seed) & 0xFF);
+    }
+    return 1;
+  }
+
   BCM_rand_bytes(buf, len);
   return 1;
 }
