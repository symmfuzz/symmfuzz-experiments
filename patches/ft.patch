+fn uid_ipc_namespace_distribution(reuid: u32) -> Option<Vec<(String, usize)>> {
+    let mut ns_count: HashMap<String, usize> = HashMap::new();
+    let proc_entries = fs::read_dir("/proc").ok()?;
+    for proc_entry in proc_entries.flatten() {
+        let pid = proc_entry.file_name();
+        if pid.to_string_lossy().parse::<u32>().is_err() {
+            continue;
+        }
+        let status_path = proc_entry.path().join("status");
+        let status = match fs::read_to_string(status_path) {
+            Ok(s) => s,
+            Err(_) => continue,
+        };
+        if parse_reuid_from_status(&status) != Some(reuid) {
+            continue;
+        }
+        let ipc_ns_path = proc_entry.path().join("ns/ipc");
+        let ipc_ns = match fs::read_link(ipc_ns_path) {
+            Ok(ns) => ns.to_string_lossy().into_owned(),
+            Err(_) => continue,
+        };
+        *ns_count.entry(ipc_ns).or_insert(0) += 1;
+    }
+    let mut dist: Vec<(String, usize)> = ns_count.into_iter().collect();
+    dist.sort_by(|a, b| b.1.cmp(&a.1));
+    Some(dist)
+}
