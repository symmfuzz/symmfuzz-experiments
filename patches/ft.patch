+        let _src = parts.next();
+        let mount_point = parts.next();
+        let fs_type = parts.next();
+        let options = parts.next();
+        if mount_point == Some("/dev/mqueue") {
+            found = true;
+            log::info!(
+                "{}: /dev/mqueue mount found, fs_type={}, options={}",
+                phase,
+                fs_type.unwrap_or("<unknown>"),
+                options.unwrap_or("<unknown>")
