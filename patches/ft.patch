+fn check_msgqueue_limit() -> Result<()> {
+    const DEFAULT_TARGET_MSGQUEUE_BYTES: u64 = 33_554_432;
+    let target_limit = std::env::var("FT_RLIMIT_MSGQUEUE")
+        .ok()
+        .and_then(|value| value.parse::<u64>().ok())
+        .unwrap_or(DEFAULT_TARGET_MSGQUEUE_BYTES);
+
+    let (mut soft_limit, mut hard_limit) =
+        getrlimit(Resource::RLIMIT_MSGQUEUE).context("Failed to read RLIMIT_MSGQUEUE")?;
+    log::info!(
+        "Current RLIMIT_MSGQUEUE soft={} hard={} target={}",
+        soft_limit,
+        hard_limit,
+        target_limit
+    );
+
+    // While we still run with elevated privileges (sudo/root), try to raise
+    // both hard and soft to the configured target first.
+    if hard_limit < target_limit || soft_limit < target_limit {
+        match setrlimit(Resource::RLIMIT_MSGQUEUE, target_limit, target_limit) {
+            Ok(()) => {
+                let (new_soft, new_hard) = getrlimit(Resource::RLIMIT_MSGQUEUE)
+                    .context("Failed to re-read RLIMIT_MSGQUEUE after raise")?;
+                soft_limit = new_soft;
+                hard_limit = new_hard;
+                log::info!(
+                    "Raised RLIMIT_MSGQUEUE to soft={} hard={}",
+                    soft_limit,
+                    hard_limit
+                );
+            }
+            Err(err) => {
+                log::warn!(
+                    "Failed to raise RLIMIT_MSGQUEUE hard/soft to {}: {:#?}",
+                    target_limit,
+                    err
+                );
+            }
+        }
+    }
+
+    // Fallback: at least raise soft to current hard to maximize usable quota.
+    if soft_limit < hard_limit {
+        log::info!(
+            "Increasing RLIMIT_MSGQUEUE soft to current hard={}",
+            hard_limit
+        );
+        setrlimit(Resource::RLIMIT_MSGQUEUE, hard_limit, hard_limit)
+            .context("Failed to raise RLIMIT_MSGQUEUE soft to hard")?;
+    }
+
+    Ok(())
+}
