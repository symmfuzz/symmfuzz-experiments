+fn mq_usage_bytes_in_current_ns() -> Option<(usize, u64)> {
+    let mut queue_count = 0usize;
+    let mut qsize_sum = 0u64;
+    let entries = fs::read_dir("/dev/mqueue").ok()?;
+    for entry in entries.flatten() {
+        let path = entry.path();
+        let content = fs::read_to_string(&path).ok()?;
+        // Format usually contains "QSIZE:<n>"
+        if let Some(idx) = content.find("QSIZE:") {
+            let tail = &content[idx + "QSIZE:".len()..];
+            let num = tail
+                .chars()
+                .take_while(|c| c.is_ascii_digit())
+                .collect::<String>()
+                .parse::<u64>()
+                .ok()?;
+            qsize_sum += num;
+            queue_count += 1;
+        }
+    }
+    Some((queue_count, qsize_sum))
+}
